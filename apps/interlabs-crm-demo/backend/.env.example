# =============================================================================
# Interlab CRM Backend — environment variable template
# Copy this file to the repo root as .env and fill in your values.
# The backend reads <repo-root>/.env via backend/src/config/env.js.
# Never commit the actual .env — it contains live secrets.
# =============================================================================

# ─── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/crmdemo

# ─── Auth / JWT ──────────────────────────────────────────────────────────────
JWT_SECRET=change-me-access-secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d
# Optional: extend refresh token for "remember me" logins (default 30d)
JWT_REMEMBER_ME_EXPIRES_IN=30d

# ─── Security ────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# reCAPTCHA v2 server-side secret. Omit to skip verification (dev/test).
# RECAPTCHA_SECRET=
# RECAPTCHA_STRICT=true

# Login rate limit (default: 5 attempts per 15 min window)
# LOGIN_RATE_LIMIT_WINDOW_MS=900000
# LOGIN_RATE_LIMIT_MAX=5

# ─── CORS / Frontend ─────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ─── MinIO / S3 Object Storage ───────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_ATTACHMENTS=attachments
MINIO_BUCKET_AVATARS=avatars
# MINIO_PUBLIC_URL=

# ─── File Upload ─────────────────────────────────────────────────────────────
UPLOAD_MAX_FILE_SIZE_MB=25
UPLOAD_PRESIGN_DOWNLOAD_SECONDS=900

# ─── Scheduler ───────────────────────────────────────────────────────────────
# Set to 'false' on all but one node in a multi-instance deploy.
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Jakarta

# ─── Redis ───────────────────────────────────────────────────────────────────
# Full Redis connection URL. Logical DB 0 is used by default.
# The test harness (test/setup.js) automatically rewrites this to /1 so
# production data is never touched during test runs.
REDIS_URL=redis://localhost:6379/0

# When 'true', Redis connection errors are logged loudly and surfaced in health
# checks. When 'false' (default), the client degrades silently; callers check
# isAvailable() before using the cache.
REQUIRE_REDIS=false

# TTL (seconds) for permission-resolver cache entries (default: 300 = 5 min).
# Raise for high-traffic deployments; lower when fast propagation is needed.
PERMISSION_CACHE_TTL=300

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Email / SMTP ────────────────────────────────────────────────────────────
# Provider selector: smtp (default) | gmail | ses | postmark | resend
# EMAIL_PROVIDER=smtp

# Default sender identity (used by factory.resolveDefaultSender until F5)
# EMAIL_FROM_NAME=Interlab Notifications
# EMAIL_FROM_ADDRESS=noreply@example.com
# EMAIL_REPLY_TO=

# SMTP transport (used when EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# Gmail via app password (used when EMAIL_PROVIDER=gmail)
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=

# AWS SES (used when EMAIL_PROVIDER=ses)
# AWS_REGION=ap-southeast-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ─── Seeding ─────────────────────────────────────────────────────────────────
# Fallback password for all 8 demo accounts when no SEED_PW_* override is set.
# DEMO_PASSWORD=Demo@2025!

# Per-role seed passwords — consumed once by scripts/seed.js, then bcrypt-hashed.
# If a role var is unset, that account falls back to DEMO_PASSWORD.
# SEED_PW_SUPERADMIN=
# SEED_PW_CEO=
# SEED_PW_SALES=
# SEED_PW_ADMINLOG=
# SEED_PW_FINANCE=
# SEED_PW_TECHNICAL=
# SEED_PW_HRGA=
# SEED_PW_TAX=
