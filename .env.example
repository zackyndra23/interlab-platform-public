# Interlab infra — credential reference (.env.example) — COMMITTED documentation.
# Real values live in .env (GITIGNORED) + /root/.coolify-secrets-backup.txt + per-service
# /root/coolify-resources/<svc>/.env + Bitwarden. Keep KEYS here IN SYNC with .env.
# Pilihan B (deviation #1): no SOPS. Secrets generated inline (openssl) on the server.
# Placeholders below show how each value is produced — never put real values in this file.

# ── Coolify (UI admin account; lives in Coolify's own DB — these keys are operator record only) ──
coolify_admin_name=<coolify-admin-display-name>
coolify_admin_email=<coolify-admin-email>
coolify_admin_password_bitwarden_entry=<bitwarden-entry-ref>   # actual pw in Bitwarden only

# ── postgres-global (cluster superuser; also = supabase service-role pw, deviation #10) ──
# postgres_global_superuser_password=GENERATE: openssl rand -hex 24

# =========================================================
# POSTGRESQL — postgres-global DBeaver connection: interlab_staging01 / interlab_db_staging (deviation #19)
# Office PC → DBeaver SSH-tunnel: SSH host 100.117.214.25 (Tailscale) port 2223 user zaky + your SSH key
# → then DB host 127.0.0.1 port 5440. interlab_staging01 OWNS interlab_db_staging (staging dev login).
# PASSWORD: openssl rand -hex 24 → real value in .env + /root/.coolify-secrets-backup.txt (key interlab_staging01_password).
# Cross-db/admin browsing instead: POSTGRES_USER=supabase_admin POSTGRES_DB=postgres (pw=postgres_global_superuser_password).
# =========================================================
POSTGRES_DB=interlab_db_staging
POSTGRES_USER=interlab_staging01
POSTGRES_PASSWORD=
POSTGRES_PORT=5440
DATABASE_URL=postgresql://interlab_staging01:<password>@127.0.0.1:5440/interlab_db_staging

# ── minio-global (root creds + scoped Supabase Storage service-account) ──
minio_global_root_user=mgroot_XXXXXXXX
minio_global_root_password=GENERATE: openssl rand -hex 24
minio_storage_sa_key=supabase-storage-sa
minio_storage_sa_secret=GENERATE: openssl rand -hex 24

# ── app database roles (per-env owner + app; least-privilege, deviation §4) ──
interlab_prod_owner_password=GENERATE: openssl rand -hex 24
interlab_prod_app_password=GENERATE: openssl rand -hex 24
interlab_staging_owner_password=GENERATE: openssl rand -hex 24
interlab_staging_app_password=GENERATE: openssl rand -hex 24

# ── Supabase (1C) ──
supabase_jwt_secret=GENERATE: openssl rand -hex 32
supabase_anon_key=HS256 JWT {"role":"anon","iss":"supabase"} signed with supabase_jwt_secret
supabase_service_role_key=HS256 JWT {"role":"service_role","iss":"supabase"} signed with supabase_jwt_secret
supabase_dashboard_password=GENERATE: openssl rand -hex 16
supabase_pg_meta_crypto_key=GENERATE: openssl rand -hex 16
supabase_s3proto_key=GENERATE: openssl rand -hex 16
supabase_s3proto_secret=GENERATE: openssl rand -hex 32

# redis-global (Phase 1.5)
redis_global_password=GENERATE: openssl rand -hex 32
